# Copy to .env and fill in. .env is gitignored.

# Free; request at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# PPA data source: "stub" generates synthetic data, "real" reads PPA_DATA_PATH
PPA_DATA_SOURCE=stub
PPA_DATA_PATH=data/raw/ppa/

# Optional: bounding box for Philadelphia OSM extraction (lon/lat)
PHL_BBOX_WEST=-75.28
PHL_BBOX_SOUTH=39.87
PHL_BBOX_EAST=-74.95
PHL_BBOX_NORTH=40.14
