data/processed/**
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!data/external/manual_counts_*.csv

# Outputs — figures and tables are tracked, fitted models and intermediate are not
outputs/models/**
